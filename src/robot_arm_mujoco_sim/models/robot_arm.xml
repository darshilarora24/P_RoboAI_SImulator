<mujoco model="robot_arm_mujoco_sim">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <visual>
    <headlight diffuse="0.9 0.9 0.9" ambient="0.35 0.35 0.35" specular="0.1 0.1 0.1"/>
    <rgba haze="0.15 0.2 0.25 1"/>
  </visual>

  <asset>
    <texture name="skybox" type="skybox" builtin="gradient" rgb1="0.18 0.26 0.36" rgb2="0.95 0.98 1.0" width="512" height="3072"/>
    <material name="ground" rgba="0.87 0.9 0.92 1"/>
    <material name="base_mat" rgba="0.2 0.24 0.28 1"/>
    <material name="link_mat" rgba="0.18 0.51 0.79 1"/>
    <material name="joint_mat" rgba="0.9 0.47 0.19 1"/>
    <material name="tool_mat" rgba="0.9 0.2 0.2 1"/>
  </asset>

  <default>
    <default class="visual_geom">
      <geom type="capsule" density="300" contype="1" conaffinity="1" friction="0.8 0.02 0.01"/>
    </default>
    <joint damping="2.5" armature="0.03" limited="true"/>
    <position kp="160" forcerange="-80 80"/>
  </default>

  <worldbody>
    <light name="sun" pos="1.2 -1.5 2.4" dir="-0.2 0.25 -1" directional="true"/>
    <geom name="floor" type="plane" material="ground" size="2.5 2.5 0.1"/>
    <body name="base_link" pos="0 0 0.08">
      <geom name="base" type="cylinder" size="0.11 0.08" material="base_mat" density="600"/>
      <body name="shoulder_yaw_link" pos="0 0 0.08">
        <joint name="shoulder_yaw" type="hinge" axis="0 0 1" range="-3.14159 3.14159"/>
        <geom name="column" type="capsule" fromto="0 0 0 0 0 0.28" size="0.055" material="joint_mat"/>
        <body name="upper_arm_link" pos="0 0 0.28">
          <joint name="shoulder_pitch" type="hinge" axis="0 1 0" range="-1.8 1.8"/>
          <geom name="upper_arm" class="visual_geom" fromto="0 0 0 0 0 0.32" size="0.045" material="link_mat"/>
          <body name="forearm_link" pos="0 0 0.32">
            <joint name="elbow_pitch" type="hinge" axis="0 1 0" range="-2.2 2.2"/>
            <geom name="forearm" class="visual_geom" fromto="0 0 0 0 0 0.26" size="0.035" material="link_mat"/>
            <body name="wrist_link" pos="0 0 0.26">
              <joint name="wrist_pitch" type="hinge" axis="0 1 0" range="-1.8 1.8"/>
              <geom name="wrist" class="visual_geom" fromto="0 0 0 0 0 0.18" size="0.028" material="link_mat"/>
              <body name="tool0" pos="0 0 0.18">
                <geom name="tool" type="sphere" size="0.04" material="tool_mat" density="200"/>
                <site name="ee_site" type="sphere" pos="0 0 0" size="0.02" rgba="1 0.95 0.1 1"/>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="shoulder_yaw_servo" joint="shoulder_yaw" ctrlrange="-3.14159 3.14159"/>
    <position name="shoulder_pitch_servo" joint="shoulder_pitch" ctrlrange="-1.8 1.8"/>
    <position name="elbow_pitch_servo" joint="elbow_pitch" ctrlrange="-2.2 2.2"/>
    <position name="wrist_pitch_servo" joint="wrist_pitch" ctrlrange="-1.8 1.8"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="0.0 0.45 -0.95 0.6"/>
  </keyframe>
</mujoco>
