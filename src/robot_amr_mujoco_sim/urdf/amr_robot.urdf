<?xml version="1.0"?>
<!--
  Minimal URDF used by robot_state_publisher to broadcast TF static frames.
  Physics is handled by MuJoCo (amr_warehouse.xml), not by this URDF.
-->
<robot name="amr_robot">

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="amr_base_link"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>

  <link name="amr_base_link">
    <visual>
      <geometry><box size="0.55 0.45 0.18"/></geometry>
      <material name="blue"><color rgba="0.18 0.40 0.78 1"/></material>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="amr_base_link"/>
    <child  link="left_wheel_link"/>
    <origin xyz="0 0.25 0" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
  </joint>
  <link name="left_wheel_link">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.10" length="0.05"/></geometry>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="amr_base_link"/>
    <child  link="right_wheel_link"/>
    <origin xyz="0 -0.25 0" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
  </joint>
  <link name="right_wheel_link">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.10" length="0.05"/></geometry>
    </visual>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="amr_base_link"/>
    <child  link="caster_link"/>
    <origin xyz="-0.22 0 -0.06" rpy="0 0 0"/>
  </joint>
  <link name="caster_link">
    <visual><geometry><sphere radius="0.04"/></geometry></visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="amr_base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 0.115" rpy="0 0 0"/>
  </joint>
  <link name="lidar_link">
    <visual><geometry><cylinder radius="0.05" length="0.05"/></geometry></visual>
  </link>

</robot>
